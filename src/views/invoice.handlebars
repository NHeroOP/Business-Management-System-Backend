<style>
  *{
    margin:0;
    padding:0;
    box-sizing:border-box;
  }

  :root{
    --bg:#f5f7fb;
    --card:#ffffff;
    --text:#0f172a;
    --muted:#64748b;
    --border:#e2e8f0;
    --primary:#1d4ed8;
    --header:#172554;
  }

  body{
    font-family:"Inter",sans-serif;
    background:var(--bg);
    padding:32px;
    color:var(--text);
  }

  .invoice{
    max-width:920px;
    margin:auto;
    background:var(--card);
    border:1px solid var(--border);
    border-radius:18px;
    overflow:hidden;
  }

  /* ================= HEADER ================= */

  .header{
    background:var(--header);
    color:white;
    padding:32px 40px;
    display:flex;
    justify-content:space-between;
    gap:40px;
    flex-wrap:wrap;
  }

  .brand h1{
    font-size:24px;
    margin-bottom:10px;
  }

  .brand p{
    color:rgba(255,255,255,.72);
    line-height:1.7;
    font-size:14px;
  }

  .invoice-meta{
    text-align:right;
  }

  .invoice-meta h2{
    font-size:34px;
    margin-bottom:18px;
    font-weight:700;
  }

  .meta{
    display:grid;
    gap:10px;
    font-size:14px;
  }

  .meta div{
    display:flex;
    gap:24px;
    justify-content:space-between;
  }

  .meta span:first-child{
    color:rgba(255,255,255,.65);
  }

  /* ================= BODY ================= */

  .body{
    padding:36px 40px;
  }

  .grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:24px;
    margin-bottom:32px;
  }

  .card{
    border:1px solid var(--border);
    border-radius:14px;
    padding:20px;
  }

  .card h3{
    font-size:13px;
    text-transform:uppercase;
    letter-spacing:.08em;
    color:var(--primary);
    margin-bottom:14px;
  }

  .card p{
    line-height:1.8;
    font-size:14px;
    color:#334155;
  }

  /* ================= TABLE ================= */

  table{
    width:100%;
    border-collapse:collapse;
    margin-bottom:32px;
  }

  thead{
    background:#f8fafc;
  }

  th{
    text-align:left;
    padding:14px 16px;
    font-size:13px;
    text-transform:uppercase;
    letter-spacing:.04em;
    color:var(--muted);
    border-bottom:1px solid var(--border);
  }

  td{
    padding:18px 16px;
    border-bottom:1px solid var(--border);
    font-size:14px;
    vertical-align:middle;
  }

  .product{
    display:flex;
    align-items:center;
    gap:14px;
  }

  .product img{
    width:54px;
    height:54px;
    object-fit:cover;
    border-radius:12px;
    border:1px solid var(--border);
    flex-shrink:0;
  }

  .product-info h4{
    font-size:14px;
    margin-bottom:4px;
  }

  .product-info p{
    font-size:13px;
    color:var(--muted);
  }

  .right{
    text-align:right;
    font-weight:500;
  }

  /* ================= SUMMARY ================= */

  .bottom{
    display:flex;
    justify-content:space-between;
    gap:32px;
    align-items:flex-start;
    flex-wrap:wrap;
  }

  .notes{
    flex:1;
    min-width:260px;
  }

  .notes h3{
    margin-bottom:12px;
    font-size:16px;
  }

  .notes p{
    color:var(--muted);
    line-height:1.8;
    font-size:14px;
  }

  .summary{
    width:320px;
    border:1px solid var(--border);
    border-radius:16px;
    padding:22px;
  }

  .summary-row{
    display:flex;
    justify-content:space-between;
    margin-bottom:14px;
    font-size:14px;
  }

  .summary-row span:first-child{
    color:var(--muted);
  }

  .total{
    margin-top:18px;
    padding-top:18px;
    border-top:1px solid var(--border);
    display:flex;
    justify-content:space-between;
    align-items:center;
  }

  .total h2{
    font-size:15px;
  }

  .total span{
    font-size:28px;
    font-weight:700;
    color:var(--primary);
  }

  /* ================= FOOTER ================= */

  .footer{
    margin-top:36px;
    padding-top:20px;
    border-top:1px solid var(--border);
    display:flex;
    justify-content:space-between;
    gap:20px;
    flex-wrap:wrap;
    font-size:13px;
    color:var(--muted);
  }

  /* ================= MOBILE ================= */

  @media(max-width:768px){
    body{
      padding:14px;
    }

    .header,
    .body{
      padding:24px;
    }

    .invoice-meta{
      text-align:left;
    }

    .grid{
      grid-template-columns:1fr;
    }

    .bottom{
      flex-direction:column;
    }

    .summary{
      width:100%;
    }

    table{
      display:block;
      overflow-x:auto;
    } 
  }
</style>


<div class="invoice">
  <!-- HEADER -->

  <header class="header">
    <div class="brand">
      <h1>NHero Studios</h1>

      <p>
        Bangalore, India <br/>
        billing@nhero.dev
      </p>

    </div>

    <div class="invoice-meta">
      <h2>Invoice</h2>

      <div class="meta">
        <div>
          <span>ID</span>
          <span>{{invoice.id}}</span>
        </div>

        <div>
          <span>Date</span>
          <span>{{invoice.issuedDate}}</span>
        </div>

        <div>
          <span>Status</span>
          <span>{{invoice.status}}</span>
        </div>
      </div>
    </div>

  </header>

  <!-- BODY -->

  <main class="body">

    <!-- INFO -->

    <div class="grid">

      <div class="card">

        <h3>Bill To</h3>
        <p>
          {{invoice.client.name}}<br/>
          {{invoice.client.company}} <br/>
          {{invoice.client.email}}
        </p>
      </div>

      <div class="card">
        <h3>Payment</h3>
        <p>
          Bank Transfer <br/>
          HDFC Bank <br/>
          Ending in 4821
        </p>
      </div>
    </div>

    <!-- TABLE -->

    <table>
      <thead>
        <tr>
          <th>Product</th>
          <th class="right">Qty</th>
          <th class="right">Price</th>
          <th class="right">Total</th>
        </tr>
      </thead>

      <tbody>
        {{#each invoice.items}}
          <tr>
            <td>
              <div class="product">
                {{#if this.productId.image}}
                  <img
                    src="{{this.productId.image}}"
                    alt=""
                  />
                {{/if}}
                <div class="product-info">
                  <h4>{{this.name}}</h4>
                  <p>{{this.productId.description}}</p>
                </div>
              </div>
            </td>
            <td class="right">{{this.quantity}}</td>
            <td class="right">₹{{this.price}}</td>
            <td class="right">₹{{this.total}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>

    <!-- BOTTOM -->

    <div class="bottom">
      <div class="notes">
        <h3>Notes</h3>
        <p>
          Thank you for your business.
          Please contact us for any invoice related questions.
        </p>
      </div>

      <div class="summary">

        <div class="summary-row">
          <span>Subtotal</span>
          <strong>₹{{invoice.subtotal}}</strong>
        </div>

        <div class="summary-row">
          <span>Tax</span>
          <strong>₹{{invoice.tax}}</strong>
        </div>

        <div class="summary-row">
          <span>Discount</span>
          <strong>{{invoice.discount}}%</strong>
        </div>

        <div class="total">
          <h2>Total</h2>
          <span>₹{{invoice.total}}</span>
        </div>
      </div>
    </div>

    <!-- FOOTER -->

    <div class="footer">
      <div>
        Generated electronically
      </div>
      <div>
        No signature required
      </div>
    </div>
  </main>

</div>